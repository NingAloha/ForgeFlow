.DS_Store
.mise.toml

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Coverage and test output
.coverage
.coverage.*
htmlcov/

# ForgeFlow runtime artifacts (runtime cache; never commit)
.forgeflow/state/
.forgeflow/generated/
.forgeflow/runs/
.forgeflow/tmp/
.forgeflow/

# Local temp dirs
tmp/
.tmp/
__tmp__/

# Runtime run outputs under repository root
runs/*
!runs/manual_reviews/
!runs/manual_reviews/**

# Sensitive local config
.env
.env.*
!.env.example
secrets/
config.local.*
llm_config.json
llm_config.local.json
model_config.json
model_config.local.json
provider_config.json
provider_config.local.json
*.secrets.json
*.local.yaml
*.local.yml
*.local.toml
*.pem
*.key
*.p12
*.crt

# Logs
*.log

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Editor and IDE files
.idea/
.vscode/
